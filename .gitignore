    
```gitignore
# =========================
# Dependencies
# =========================
node_modules/

# =========================
# Playwright
# =========================
playwright-report/
test-results/
blob-report/

# =========================
# Allure
# =========================
allure-results/
allure-report/

# =========================
# Coverage
# =========================
coverage/
.nyc_output/

# =========================
# Build Output
# =========================
dist/
build/
out/

# =========================
# TypeScript
# =========================
*.tsbuildinfo

# =========================
# Environment Files
# =========================
.env
.env.*
!.env.example

# =========================
# Logs
# =========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# Playwright Artifacts
# =========================
test-results/**/*.png
test-results/**/*.jpg
test-results/**/*.jpeg
test-results/**/*.webm
test-results/**/*.mp4
test-results/**/*.zip
*.trace

# =========================
# IDE
# =========================
.vscode/
.idea/
*.iml

# =========================
# OS Files
# =========================
.DS_Store
Thumbs.db

# =========================
# Temporary Files
# =========================
.cache/
tmp/
temp/
```

